PORT=8080
HOST=0.0.0.0
RELAY_PATH=/jira/events
HEALTH_PATH=/healthz

# Required: Jira Automation -> relay auth
RELAY_AUTH_TOKEN=REPLACE_ME

# Optional: Jira native admin webhook HMAC secret.
# If omitted, relay falls back to RELAY_AUTH_TOKEN for signature verification.
JIRA_WEBHOOK_SECRET=REPLACE_WITH_JIRA_WEBHOOK_SECRET

# Optional: derive Jira links if webhook payload does not include them
JIRA_BASE_URL=https://netstars-sre-demo.atlassian.net
JIRA_BOARD_URL=https://netstars-sre-demo.atlassian.net/jira/software/projects/KAN/boards/2
JIRA_BOARD_NAME=龙虾骑士看板

# Forward target (OpenClaw hooks)
LOBSTER_TARGET_URL=http://127.0.0.1:18789/hooks/jira-relay

# Optional: relay -> OpenClaw hook auth
LOBSTER_AUTH_TOKEN=REPLACE_WITH_OPENCLAW_HOOK_TOKEN

REQUEST_TIMEOUT_MS=10000
BODY_LIMIT_BYTES=1048576
